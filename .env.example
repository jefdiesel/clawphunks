# Server
PORT=3000

# Network (base-sepolia for testnet, base for mainnet)
NETWORK=base-sepolia

# x402 Payment
PAYMENT_RECIPIENT=0xYourWalletAddress
MINT_PRICE_USDC=1.99

# Ethereum L1 (for minting ethscriptions)
ETHEREUM_RPC_URL=https://eth.llamarpc.com
SIGNER_PRIVATE_KEY=0xYourPrivateKey

# Art storage (Cloudflare R2)
R2_BUCKET_URL=https://clawphunks.your-domain.com
R2_BUCKET_NAME=clawphunks
CF_ACCOUNT_ID=your-account-id
CF_R2_ACCESS_KEY_ID=your-access-key
CF_R2_SECRET_ACCESS_KEY=your-secret-key

# Supabase (for marketplace)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key
